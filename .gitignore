# ── JSON-Schutz: Nur sensible Daten blockieren ────────
# Blockiert echten Testfragen (wegen privater Inhalte)
tools/evaluation/testfragen.json
tools/evaluation/testfragen_big_run.json

# Blockiert alle automatisch generierten Bewertungs-JSONs des Auto-Scorers
tools/evaluation/results/*.json

# Blockiert lokalen Konfigurations-Müll deiner Editoren
.vscode/*.json
.idea/*.json

.claude/
